<%= form_with(model: recipe) do |form| %>
  <fieldset>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </fieldset>

  <fieldset>
    <%= form.label :steps %>
    <%= form.textarea :steps %>
  </fieldset>

  <fieldset>
    <%= form.label :preparation_time_seconds %>
    <%= form.number_field :preparation_time_seconds %>
  </fieldset>

  <fieldset>
    <%= form.label :cooking_time_seconds %>
    <%= form.number_field :cooking_time_seconds %>
  </fieldset>

  <%= form.submit %>
<% end %>
